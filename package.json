{
  "name": "drexo",
  "version": "0.2.0",
  "description": "The bridge from BI to AI — turn Tableau workbooks into structured, AI-ready metadata",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "drexo": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:watch": "vitest",
    "lint": "echo \"Lint not configured yet\"",
    "link": "npm link"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raguvindtharanitharan/drexo.git"
  },
  "keywords": [
    "tableau",
    "bi",
    "ai",
    "metadata",
    "migration",
    "dashboard",
    "cli",
    "react",
    "data-visualization",
    "analytics-engineering"
  ],
  "author": "Raguvind Tharanitharan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/raguvindtharanitharan/drexo/issues"
  },
  "homepage": "https://github.com/raguvindtharanitharan/drexo#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.15.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "adm-zip": "^0.5.17",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fast-xml-parser": "^5.8.0",
    "yaml": "^2.0.0"
  }
}
